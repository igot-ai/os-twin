# ── AI Provider Keys (set at least one) ──────────────────────────────────────
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=
# AZURE_OPENAI_API_KEY=
# BASETEN_API_KEY=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── AI Model Settings ────────────────────────────────────────────────────────
GEMINI_MODEL=google-vertex/gemini-3-flash-preview

# ── Dashboard ────────────────────────────────────────────────────────────────
# OSTWIN_API_KEY=           # Auto-generated on install; used for CLI ↔ Dashboard auth

# ── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=         # Optional: restrict to a single chat
# TELEGRAM_PAIRING_CODE=    # Optional: custom pairing code (default: random)

# ── ngrok Tunnel (auto-starts when NGROK_AUTHTOKEN is set) ───────────
# NGROK_AUTHTOKEN=          # Get from https://dashboard.ngrok.com
# NGROK_DOMAIN=             # Optional: custom/static domain (paid plans)

# ── Discord Bot ──────────────────────────────────────────────────────────────
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
GUILD_ID=
# DISCORD_ALLOWED_CHANNELS= # Optional: comma-separated channel IDs (text & voice) to restrict the bot

# ── CocoIndex (memory/indexing) ──────────────────────────────────────────────
# COCOINDEX_DATABASE_URL=postgres://cocoindex:cocoindex@localhost:5433/cocoindex

# ── OpenCode Server (master agent backend) ──────────────────────────────────
# OPENCODE_BASE_URL=http://127.0.0.1:4096   # Where `opencode serve` is reachable
# OPENCODE_SERVER_USERNAME=opencode         # Basic-auth username (server default)
# OPENCODE_SERVER_PASSWORD=                 # Set if `opencode serve` was started with a password
# OPENCODE_MAX_SESSIONS=1000                # LRU bound on the conversation→session map

# ── Agent OS ─────────────────────────────────────────────────────────────────
# AGENT_OS_LOG_LEVEL=INFO
# OSTWIN_LOG_LEVEL=INFO
# WARROOMS_DIR=             # Override war-rooms data directory
