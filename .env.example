# ── AI Provider Keys (set at least one) ──────────────────────────────────────
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=
# AZURE_OPENAI_API_KEY=
# BASETEN_API_KEY=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── AI Model Settings ────────────────────────────────────────────────────────
GEMINI_MODEL=gemini-3-flash-preview

# ── Dashboard ────────────────────────────────────────────────────────────────
DASHBOARD_URL=http://localhost:9000
# DASHBOARD_PORT=9000
# DASHBOARD_HOST=0.0.0.0
# OSTWIN_API_KEY=           # Auto-generated on install; used for CLI ↔ Dashboard auth

# ── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=         # Optional: restrict to a single chat
# TELEGRAM_PAIRING_CODE=    # Optional: custom pairing code (default: random)

# ── Discord Bot ──────────────────────────────────────────────────────────────
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
GUILD_ID=
# DISCORD_ALLOWED_CHANNELS= # Optional: comma-separated channel IDs (text & voice) to restrict the bot

# ── CocoIndex (memory/indexing) ──────────────────────────────────────────────
# COCOINDEX_DATABASE_URL=postgres://cocoindex:cocoindex@localhost:5433/cocoindex

# ── Agent OS ─────────────────────────────────────────────────────────────────
# AGENT_OS_LOG_LEVEL=INFO
# OSTWIN_LOG_LEVEL=INFO
# WARROOMS_DIR=             # Override war-rooms data directory
