{
  "initial_state": "developing",
  "states": {
    "developing": {
      "type": "agent",
      "role": "manager",
      "transitions": {
        "done": "architect-review"
      }
    },
    "architect-review": {
      "type": "agent",
      "role": "architect",
      "transitions": {
        "pass": "passed",
        "fail": "manager-triage",
        "escalate": "manager-triage"
      }
    },
    "manager-triage": {
      "type": "builtin",
      "role": "manager",
      "transitions": {}
    },
    "plan-revision": {
      "type": "builtin",
      "role": "manager",
      "transitions": {}
    },
    "fixing": {
      "type": "agent",
      "role": "manager",
      "transitions": {
        "done": "architect-review"
      }
    }
  }
}
