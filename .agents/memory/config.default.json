{
  "_comment": "Default configuration for the Agentic Memory system. All values can be overridden by environment variables prefixed with MEMORY_.",

  "llm": {
    "backend": "gemini",
    "model": "gemini-3-flash-preview"
  },

  "embedding": {
    "backend": "gemini",
    "model": "gemini-embedding-001"
  },

  "vector": {
    "backend": "zvec"
  },

  "search": {
    "similarity_weight": 0.8,
    "decay_half_life_days": 30.0
  },

  "evolution": {
    "max_links": 3,
    "context_aware": true,
    "context_aware_tree": false
  },

  "sync": {
    "auto_sync": true,
    "auto_sync_interval": 60,
    "conflict_resolution": "last_modified"
  },

  "disabled_tools": [
    "read_memory",
    "update_memory",
    "delete_memory",
    "link_memories",
    "unlink_memories",
    "memory_stats",
    "sync_from_disk",
    "sync_to_disk",
    "graph_snapshot"
  ],

  "pool": {
    "_comment": "Configuration for the HTTP memory pool (Plan 007). Only used when the memory MCP is mounted inside the dashboard, not in stdio mode.",
    "idle_timeout_s": 300,
    "max_instances": 10,
    "eviction_policy": "lru",
    "ml_preload": true,
    "ml_ready_timeout_s": 30,
    "sync_interval_s": 60,
    "sync_on_kill": true,
    "allowed_paths": null,
    "sweep_interval_s": 30
  }
}
