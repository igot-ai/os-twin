{
  "mcpServers": {
    "channel": {
      "command": "${AGENT_DIR}/.venv/bin/python",
      "args": [
        "${AGENT_DIR}/mcp/channel-server.py"
      ],
      "env": {
        "AGENT_OS_ROOT": "."
      }
    },
    "warroom": {
      "command": "${AGENT_DIR}/.venv/bin/python",
      "args": [
        "${AGENT_DIR}/mcp/warroom-server.py"
      ],
      "env": {
        "AGENT_OS_ROOT": "."
      }
    },
    "memory": {
      "command": "${OSTWIN_PYTHON:-${HOME}/.ostwin/.venv/bin/python}",
      "args": [
        "${HOME}/os-twin/A-mem-sys/mcp_server.py"
      ],
      "env": {
        "GOOGLE_API_KEY": "${GOOGLE_API_KEY}"
        }
    }
  }
}
