{
  "mcpServers": {
    "channel": {
      "command": "${AGENT_DIR}/.venv/bin/python",
      "args": [
        "${AGENT_DIR}/mcp/channel-server.py"
      ],
      "env": {
        "AGENT_OS_ROOT": "."
      }
    },
    "warroom": {
      "command": "${AGENT_DIR}/.venv/bin/python",
      "args": [
        "${AGENT_DIR}/mcp/warroom-server.py"
      ],
      "env": {
        "AGENT_OS_ROOT": "."
      }
    },
    "memory": {
      "command": "${HOME}/os-twin/A-mem-sys/.venv/bin/python",
      "args": [
        "${HOME}/os-twin/A-mem-sys/mcp_server.py"
      ],
      "env": {
        "GOOGLE_API_KEY": "${GOOGLE_API_KEY}",
        "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY}"
      }
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"],
      "env": {}
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"],
      "env": {}
    },
    "serena": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide-assistant"
      ],
      "disabledTools": [
        "switch_modes"
      ]
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "ai-game-developer": {
      "disabled": false,
      "serverUrl": "http://localhost:51657"
    }
  }
}
