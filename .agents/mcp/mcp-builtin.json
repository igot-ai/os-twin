{
  "mcpServers": {
    "channel": {
      "command": "${AGENT_DIR}/.venv/bin/python",
      "args": [
        "${AGENT_DIR}/mcp/channel-server.py"
      ],
      "env": {
        "AGENT_OS_ROOT": "."
      }
    },
    "warroom": {
      "command": "${AGENT_DIR}/.venv/bin/python",
      "args": [
        "${AGENT_DIR}/mcp/warroom-server.py"
      ],
      "env": {
        "AGENT_OS_ROOT": "."
      }
    },
    "memory": {
      "type": "sse",
      "url": "http://127.0.0.1:6463/sse"
    }
  }
}
