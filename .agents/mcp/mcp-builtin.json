{
  "mcp": {
    "channel": {
      "type": "local",
      "command": [
        "{env:OSTWIN_PYTHON}",
        "{env:AGENT_DIR}/mcp/channel-server.py"
      ],
      "environment": {
        "AGENT_OS_ROOT": "{env:PROJECT_DIR}"
      }
    },
    "warroom": {
      "type": "local",
      "command": [
        "{env:OSTWIN_PYTHON}",
        "{env:AGENT_DIR}/mcp/warroom-server.py"
      ],
      "environment": {
        "AGENT_OS_ROOT": "{env:PROJECT_DIR}"
      }
    },
    "memory": {
      "type": "remote",
      "url": "http://localhost:3366/api/knowledge/mcp?persist_dir={env:PROJECT_DIR}/.memory"
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "environment": {
        "PATH": "{env:PATH}"
      }
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ],
      "environment": {
        "PATH": "{env:PATH}"
      }
    }
  }
}
