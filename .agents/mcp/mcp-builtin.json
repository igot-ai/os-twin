{
  "mcpServers": {
    "channel": {
      "command": "${AGENT_DIR}/.venv/bin/python",
      "args": [
        "${AGENT_DIR}/.agents/mcp/channel-server.py"
      ],
      "env": {
        "AGENT_OS_ROOT": "."
      }
    },
    "warroom": {
      "command": "${AGENT_DIR}/.venv/bin/python",
      "args": [
        "${AGENT_DIR}/.agents/mcp/warroom-server.py"
      ],
      "env": {
        "AGENT_OS_ROOT": "."
      }
    },
    "memory": {
      "command": "${AGENT_DIR}/.venv/bin/python",
      "args": [
        "${AGENT_DIR}/.agents/mcp/memory-server.py"
      ],
      "env": {
        "AGENT_OS_ROOT": "${PROJECT_DIR}"
      }
    },
    "ai-game-developer": {
      "type": "http",
      "url": "http://localhost:51657"
    }
  }
}