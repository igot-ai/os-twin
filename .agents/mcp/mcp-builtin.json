{
  "mcpServers": {
    "channel": {
      "command": "python",
      "args": [
        "${AGENT_DIR}/mcp/channel-server.py"
      ],
      "env": {
        "AGENT_OS_ROOT": "."
      }
    },
    "warroom": {
      "command": "python",
      "args": [
        "${AGENT_DIR}/mcp/warroom-server.py"
      ],
      "env": {
        "AGENT_OS_ROOT": "."
      }
    },
    "serena": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide-assistant"
      ],
      "disabledTools": [
        "switch_modes"
      ]
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "ai-game-developer": {
      "disabled": false,
      "serverUrl": "http://localhost:22418"
    }
  }
}