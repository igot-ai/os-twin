{
  "mcp": {
    "channel": {
      "type": "local",
      "command": [
        "python",
        "{env:AGENT_DIR}/mcp/channel-server.py"
      ],
      "environment": {
        "AGENT_OS_ROOT": "."
      }
    },
    "warroom": {
      "type": "local",
      "command": [
        "python",
        "{env:AGENT_DIR}/mcp/warroom-server.py"
      ],
      "environment": {
        "AGENT_OS_ROOT": "."
      }
    },
    "memory": {
      "type": "local",
      "command": [
        "python",
        "{env:AGENT_DIR}/mcp/memory-server.py"
      ],
      "environment": {
        "AGENT_OS_ROOT": "{env:PROJECT_DIR}"
      }
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "environment": {}
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ],
      "environment": {}
    }
  }
}
