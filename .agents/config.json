{
  "version": "0.1.0",
  "project_name": "ostwin",
  "manager": {
    "default_model": "google-vertex/gemini-3-flash-preview",
    "poll_interval_seconds": 5,
    "max_concurrent_rooms": 50,
    "max_engineer_retries": 10,
    "auto_approve_tools": true,
    "state_timeout_seconds": 2400,
    "auto_expand_plan": false,
    "preflight_skill_check": "warn",
    "smart_assignment": false,
    "dynamic_pipelines": true,
    "capability_matching": true,
    "external_roles_dirs": [],
    "timeout_seconds": 2400,
    "skill_refs": [
      "risk-decision",
      "war-room-communication"
    ]
  },
  "architect": {
    "default_model": "google-vertex/gemini-3-flash-preview",
    "cli": "agent",
    "shell_allow_list": "all",
    "auto_approve": true,
    "timeout_seconds": 1200,
    "max_prompt_bytes": 102400,
    "no_mcp": true
  },
  "engineer": {
    "cli": "agent",
    "default_model": "google-vertex/gemini-3-flash-preview",
    "shell_allow_list": "all",
    "auto_approve": true,
    "timeout_seconds": 1200,
    "max_prompt_bytes": 102400,
    "no_mcp": false,
    "instances": {
      "fe": {
        "display_name": "Frontend Engineer",
        "default_model": "google-vertex/gemini-3-flash-preview",
        "timeout_seconds": 2400,
        "working_dir": "dashboard",
        "skills": [
          "javascript",
          "typescript",
          "css",
          "html"
        ]
      },
      "be": {
        "display_name": "Backend Engineer",
        "default_model": "google-vertex/gemini-3-flash-preview",
        "timeout_seconds": 1200,
        "working_dir": "api",
        "skills": [
          "python",
          "sql",
          "docker",
          "powershell"
        ]
      }
    }
  },
  "technical-writer": {
    "cli": "agent",
    "default_model": "google-vertex/gemini-3-flash-preview",
    "shell_allow_list": "all",
    "auto_approve": true,
    "timeout_seconds": 1200,
    "max_prompt_bytes": 102400,
    "no_mcp": true
  },
  "tech-artist": {
    "cli": "agent",
    "default_model": "google-vertex/gemini-3-flash-preview",
    "shell_allow_list": "all",
    "auto_approve": true,
    "timeout_seconds": 1200,
    "max_prompt_bytes": 102400,
    "no_mcp": true
  },
  "editor": {
    "cli": "agent",
    "default_model": "google-vertex/gemini-3-flash-preview",
    "shell_allow_list": "all",
    "auto_approve": true,
    "timeout_seconds": 600,
    "max_prompt_bytes": 102400,
    "no_mcp": true
  },
  "reporter": {
    "cli": "agent",
    "default_model": "google-vertex/gemini-3-flash-preview",
    "shell_allow_list": "all",
    "auto_approve": true,
    "timeout_seconds": 1200,
    "max_prompt_bytes": 102400
  },
  "qa": {
    "cli": "agent",
    "default_model": "google-vertex/gemini-3-flash-preview",
    "approval_mode": "auto-approve",
    "timeout_seconds": 600,
    "no_mcp": true
  },
  "memory": {
    "enabled": true,
    "max_summary_bytes": 4096,
    "max_detail_bytes": 16384,
    "max_context_entries": 15,
    "auto_publish_on_done": true
  },
  "channel": {
    "format": "jsonl",
    "max_message_size_bytes": 65536
  },
  "release": {
    "require_signoffs": [
      "engineer",
      "qa",
      "manager"
    ],
    "auto_draft": true
  },
  "test-engineer": {
    "default_model": "google-vertex/gemini-3-flash-preview",
    "timeout_seconds": 600,
    "skill_refs": [
      "web-research"
    ]
  },
  "unique-role": {
    "default_model": "google-vertex/gemini-3-flash-preview",
    "timeout_seconds": 300
  },
  "active-role": {
    "default_model": "gemini-3.1-flash-lite-preview",
    "timeout_seconds": 300
  },
  "autonomy": {
    "idle_explore_enabled": true,
    "interval": 3600
  },
  "runtime": {
    "max_concurrent_rooms": 9999
  }
}