        "working_dir": "dashboard",
        "skills": [
          "javascript",
          "typescript",
          "css",
          "html"
        ]
      },
      "be": {
        "display_name": "Backend Engineer",
        "default_model": "google-vertex/gemini-3-flash-preview",
        "timeout_seconds": 1200,
