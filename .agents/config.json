{
  "version": "0.1.0",
  "project_name": "ostwin",
  "manager": {
    "poll_interval_seconds": 5,
    "max_concurrent_rooms": 50,
    "max_engineer_retries": 3,
    "auto_approve_tools": true,
    "state_timeout_seconds": 900
  },
  "engineer": {
    "cli": "deepagents",
    "default_model": "gemini-2.5-pro",
    "shell_allow_list": "all",
    "auto_approve": true,
    "timeout_seconds": 600,
    "max_prompt_bytes": 102400
  },
  "qa": {
    "cli": "gemini",
    "default_model": "gemini-2.5-pro",
    "approval_mode": "yolo",
    "timeout_seconds": 300
  },
  "channel": {
    "format": "jsonl",
    "max_message_size_bytes": 65536
  },
  "release": {
    "require_signoffs": [
      "engineer",
      "qa",
      "manager"
    ],
    "auto_draft": true
  }
}