{
  "version": "0.1.0",
  "project_name": "ostwin",
  "manager": {
    "default_model": "google-vertex/gemini-3-flash-preview",
    "poll_interval_seconds": 5,
    "max_concurrent_rooms": 50,
    "max_engineer_retries": 10,
    "auto_approve_tools": true,
    "state_timeout_seconds": 2400,
    "auto_expand_plan": false,
