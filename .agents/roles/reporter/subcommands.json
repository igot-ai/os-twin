{
  "role": "reporter",
  "language": "python",
  "module_root": ".",
  "subcommands": [
    {
      "name": "generate",
      "type": "cli",
      "entrypoint": "cli.py::main",
      "invoke": "python -m reporter generate {args}",
      "description": "Generate a report.",
      "args_schema": {
        "positional": [
          "spec_file"
        ],
        "optional": {
          "-o|--output": "Output PDF path"
        }
      }
    },
    {
      "name": "validate",
      "type": "cli",
      "entrypoint": "cli.py::main",
      "invoke": "python -m reporter validate {args}",
      "description": "Validate a report spec."
    },
    {
      "name": "list-components",
      "type": "cli",
      "entrypoint": "cli.py::main",
      "invoke": "python -m reporter list-components",
      "description": "List all reporter components."
    }
  ]
}
