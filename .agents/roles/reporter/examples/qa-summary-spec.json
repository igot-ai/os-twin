{
  "title": "QA Summary Report",
  "subtitle": "Quality Assurance Review",
  "author": "igot.ai",
  "brand_file": "../brand.json",
  "page_size": "A4",
  "output": "qa-summary-report.pdf",
  "pages": [
    {
      "type": "cover",
      "title": "igot.ai",
      "subtitle": "QA Summary Report",
      "version_line": "Release v2.4.0  |  March 2026"
    },
    {
      "type": "toc",
      "items": [
        { "num": "01", "title": "Test Summary", "desc": "Overall test execution results" },
        { "num": "02", "title": "Test Results", "desc": "Detailed results by suite" },
        { "num": "03", "title": "Bug Distribution", "desc": "Severity and category breakdown" },
        { "num": "04", "title": "QA Checklist", "desc": "Release readiness verification" }
      ]
    },
    {
      "type": "metrics",
      "heading": "Test Summary",
      "subtitle": "Overall test execution results for v2.4.0",
      "cards": [
        { "label": "Total Tests", "value": "328", "trend": "+45" },
        { "label": "Passed", "value": "312", "trend": "+40" },
        { "label": "Failed", "value": "8", "trend": "-3" },
        { "label": "Skipped", "value": "8", "trend": "" },
        { "label": "Pass Rate", "value": "95.1%", "trend": "+2.1%" },
        { "label": "Avg Duration", "value": "4.2s", "trend": "-0.8s" }
      ]
    },
    {
      "type": "data_table",
      "heading": "Test Results by Suite",
      "subtitle": "Breakdown by test suite",
      "columns": ["Suite", "Total", "Passed", "Failed", "Skipped", "Duration"],
      "col_widths": [40, 18, 18, 18, 18, 22],
      "rows": [
        ["Unit — Core Engine", "142", "140", "1", "1", "12.3s"],
        ["Unit — API Layer", "88", "85", "2", "1", "8.7s"],
        ["Integration — Auth", "34", "32", "2", "0", "45.2s"],
        ["Integration — Data Pipeline", "28", "24", "2", "2", "62.1s"],
        ["E2E — Critical Paths", "18", "16", "1", "1", "180.5s"],
        ["Performance — Load Tests", "12", "10", "0", "2", "240.0s"],
        ["Security — OWASP Scan", "6", "5", "0", "1", "95.3s"]
      ]
    },
    {
      "type": "pie_chart",
      "heading": "Bug Distribution",
      "subtitle": "Open bugs by severity",
      "donut": true,
      "slices": [
        { "label": "Critical", "value": 2, "color": "#DC2626" },
        { "label": "High", "value": 5, "color": "#F97316" },
        { "label": "Medium", "value": 12, "color": "#3375B5" },
        { "label": "Low", "value": 8, "color": "#38A3A5" }
      ]
    },
    {
      "type": "checklist",
      "heading": "QA Checklist",
      "subtitle": "Release readiness verification for v2.4.0",
      "dont_heading": "Blockers identified during QA:",
      "dont": [
        "Auth token refresh fails under high concurrency (BUG-142)",
        "Pipeline timeout on datasets > 10GB (BUG-145)"
      ],
      "do_heading": "Release-Ready Items",
      "do": [
        "All P0 critical path tests passing",
        "Security scan — no critical vulnerabilities",
        "Performance baseline met (p99 < 200ms)",
        "API backward compatibility verified",
        "Documentation updated for new endpoints",
        "Staging environment smoke test passed"
      ]
    }
  ]
}
