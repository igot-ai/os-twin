{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent OS Role Registry",
  "description": "Catalog of all available roles for war-room assignment",
  "version": "0.2.0",
  "roles": [
    {
      "name": "engineer",
      "description": "Software engineer — implements features, writes tests, fixes bugs",
      "runner": "roles/engineer/Start-Engineer.ps1",
      "runner_legacy": "roles/engineer/run.sh",
      "definition": "roles/engineer/role.json",
      "prompt": "roles/engineer/SKILL.md",
      "default_assignment": true,
      "instance_support": true,
      "supported_task_types": [
        "task",
        "epic"
      ],
      "capabilities": [
        "code-generation",
        "file-editing",
        "shell-execution",
        "testing",
        "refactoring"
      ],
      "quality_gates": [
        "unit-tests",
        "lint-clean",
        "no-hardcoded-secrets"
      ],
      "default_model": "gemini-3-flash-preview"
    },
    {
      "name": "qa",
      "description": "QA engineer — reviews code, verifies requirements, validates quality",
      "runner": "roles/qa/Start-QA.ps1",
      "runner_legacy": "roles/qa/run.sh",
      "definition": "roles/qa/role.json",
      "prompt": "roles/qa/SKILL.md",
      "default_assignment": false,
      "supported_task_types": [
        "review"
      ],
      "capabilities": [
        "code-review",
        "test-execution",
        "shell-execution",
        "security-review"
      ],
      "quality_gates": [
        "verdict-required",
        "evidence-based-review"
      ],
      "default_model": "gemini-3-flash-preview"
    },
    {
      "name": "architect",
      "description": "Software architect — designs systems, reviews architecture, makes technical decisions",
      "runner": "roles/architect/Start-Architect.ps1",
      "definition": "roles/architect/role.json",
      "prompt": "roles/architect/SKILL.md",
      "default_assignment": false,
      "supported_task_types": [
        "design",
        "review",
        "epic"
      ],
      "capabilities": [
        "architecture-design",
        "code-review",
        "documentation",
        "technical-decisions"
      ],
      "quality_gates": [
        "design-review",
        "scalability-check",
        "security-review"
      ],
      "default_model": "gemini-3-flash-preview"
    },
    {
      "name": "manager",
      "description": "Manager — orchestrates war-rooms, routes work, handles retries, skill discovery, and release",
      "runner": "roles/manager/Start-ManagerLoop.ps1",
      "runner_legacy": "roles/manager/loop.sh",
      "definition": "roles/manager/role.json",
      "prompt": "roles/manager/SKILL.md",
      "default_assignment": false,
      "supported_task_types": [
        "orchestration"
      ],
      "capabilities": [
        "task-routing",
        "retry-management",
        "release-coordination",
        "deadlock-detection",
        "skill-search",
        "skill-install"
      ],
      "quality_gates": [],
      "default_model": "gemini-3.1-pro-preview"
    },
    {
      "name": "reporter",
      "description": "Report generator — creates structured PDF reports from data specs",
      "runner": "roles/reporter/Start-Reporter.ps1",
      "definition": "roles/reporter/role.json",
      "prompt": "roles/reporter/SKILL.md",
      "default_assignment": false,
      "supported_task_types": [
        "task",
        "epic"
      ],
      "capabilities": [
        "report-generation",
        "data-visualization",
        "document-composition",
        "pdf-output"
      ],
      "quality_gates": [
        "report-renders",
        "no-empty-pages"
      ],
      "default_model": "gemini-3-flash-preview"
    }
  ],
  "assignment_rules": {
    "default_role": "engineer",
    "review_role": "qa",
    "design_role": "architect",
    "orchestration_role": "manager"
  },
  "extensibility": {
    "custom_roles_dir": "roles/",
    "auto_discover": true,
    "required_files": [
      "role.json"
    ],
    "optional_files": [
      "ROLE.md",
      "skills/"
    ],
    "capability_aliases": {
      "db": "database",
      "sql": "database",
      "postgres": "database",
      "mysql": "database",
      "mongo": "database",
      "react": "frontend",
      "vue": "frontend",
      "angular": "frontend",
      "css": "frontend",
      "ui": "frontend",
      "ux": "frontend",
      "devops": "infrastructure",
      "ci-cd": "infrastructure",
      "ci/cd": "infrastructure",
      "docker": "infrastructure",
      "k8s": "infrastructure",
      "kubernetes": "infrastructure",
      "auth": "security",
      "owasp": "security",
      "encryption": "security",
      "a11y": "accessibility",
      "wcag": "accessibility",
      "screen-reader": "accessibility"
    }
  },
  "skills": {
    "skills_dir": "skills/",
    "auto_discover": true,
    "required_files": [
      "SKILL.md"
    ],
    "available": [
      {
        "name": "lang",
        "description": "Fetch LangGraph documentation for accurate, up-to-date guidance",
        "path": "skills/global/lang/SKILL.md",
        "skills": "engineer, python, code-generation",
        "tags": ["engineer", "python", "code-generation"],
        "trust_level": "core"
      },
      {
        "name": "create-role",
        "description": "Scaffold a new agent role — generates role.json, ROLE.md, and registers in registry.json",
        "path": "skills/roles/architect/create-role/SKILL.md",
        "skills": "architect, manager, scaffolding",
        "tags": ["architect", "manager", "scaffolding"],
        "trust_level": "core"
      },
      {
        "name": "create-architecture",
        "description": "Generate architecture docs for an epic — ADRs, component diagrams, data flows, tech-stack rationale",
        "path": "skills/global/create-architecture/SKILL.md",
        "skills": "architect, documentation, design",
        "tags": ["architect", "documentation", "design"],
        "trust_level": "core"
      },
      {
        "name": "create-lifecycle",
        "description": "Define and scaffold the lifecycle for an epic — states, quality gates, required artifacts, escalation rules",
        "path": "skills/global/create-lifecycle/SKILL.md",
        "skills": "architect, manager, process",
        "tags": ["architect", "manager", "process"],
        "trust_level": "core"
      }
    ]
  }
}

