#!/usr/bin/env bash
# ostwin CLI — unified entry point for Agent OS
#
# Thin wrapper: sets up environment, then delegates to ostwin.ps1 (PowerShell)
# which is the canonical implementation of all CLI commands.
#
# Usage: ostwin <command> [options]

set -euo pipefail

# ──────────────────────────────────────────────────────────────────────────────
# 1. Activate the Ostwin venv — makes `python` resolve to the managed interpreter
# ──────────────────────────────────────────────────────────────────────────────
OSTWIN_HOME="${OSTWIN_HOME:-$HOME/.ostwin}"
export OSTWIN_HOME

if [[ -f "$OSTWIN_HOME/.venv/bin/activate" ]]; then
  source "$OSTWIN_HOME/.venv/bin/activate"
fi

# ──────────────────────────────────────────────────────────────────────────────
# 2. Load .env files (global → project)
# ──────────────────────────────────────────────────────────────────────────────
_load_env_file() {
  local envfile="$1"
  [[ -f "$envfile" ]] || return 0
  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ "$line" =~ ^[[:space:]]*# ]] && continue
    [[ -z "${line// /}" ]] && continue
    local key="${line%%=*}"
    local val="${line#*=}"
    key="${key// /}"
    val="${val#\"}" ; val="${val%\"}"
    val="${val#\'}" ; val="${val%\'}"
    if [[ -n "$key" && -z "${!key+x}" ]]; then
      export "$key=$val"
    fi
  done < "$envfile"
}
_load_env_file "$HOME/.ostwin/.env"

# ──────────────────────────────────────────────────────────────────────────────
# 3. Resolve AGENTS_DIR
# ──────────────────────────────────────────────────────────────────────────────
AGENTS_DIR=""
if [[ -d "$(pwd)/.agents" && -f "$(pwd)/.agents/config.json" ]]; then
  AGENTS_DIR="$(cd "$(pwd)/.agents" && pwd)"
elif [[ -f "$(pwd)/config.json" && -d "$(pwd)/bin" ]]; then
  AGENTS_DIR="$(pwd)"
else
  _dir="$(pwd)"
  while [[ "$_dir" != "/" ]]; do
    if [[ -f "$_dir/config.json" && -d "$_dir/bin" ]]; then
      AGENTS_DIR="$_dir"; break
    fi
    if [[ -d "$_dir/.agents" && -f "$_dir/.agents/config.json" ]]; then
      AGENTS_DIR="$(cd "$_dir/.agents" && pwd)"; break
    fi
    _dir="$(dirname "$_dir")"
  done
fi
if [[ -z "$AGENTS_DIR" ]]; then
  if [[ -L "$0" ]]; then
    REAL_PATH="$(readlink "$0")"
    BIN_DIR="$(cd "$(dirname "$REAL_PATH")" && pwd)"
  else
    BIN_DIR="$(cd "$(dirname "$0")" && pwd)"
  fi
  AGENTS_DIR="$(cd "$BIN_DIR/.." && pwd)"
fi
export AGENTS_DIR

# Load project .env
_load_env_file "$AGENTS_DIR/.env"

# ──────────────────────────────────────────────────────────────────────────────
# 4. Export defaults for ostwin.ps1
# ──────────────────────────────────────────────────────────────────────────────
export WARROOMS_DIR="${WARROOMS_DIR:-$(pwd)/.war-rooms}"
export DASHBOARD_URL="${DASHBOARD_URL:-http://localhost:3366}"

# ──────────────────────────────────────────────────────────────────────────────
# 5. Delegate to ostwin.ps1 via pwsh
# ──────────────────────────────────────────────────────────────────────────────
if ! command -v pwsh &>/dev/null; then
  echo ""
  echo "  ✗ PowerShell (pwsh) is required but not found." >&2
  echo "" >&2
  echo "  Install it with:" >&2
  if [[ "$(uname -s)" == "Darwin" ]]; then
    echo "    brew install powershell" >&2
  else
    echo "    See https://aka.ms/install-powershell" >&2
  fi
  echo "" >&2
  echo "  Or re-run the Ostwin installer:" >&2
  echo "    $AGENTS_DIR/install.sh" >&2
  echo "" >&2
  exit 1
fi

exec pwsh -NoProfile -File "$AGENTS_DIR/bin/ostwin.ps1" "$@"
