#!/usr/bin/env bash
# ostwin CLI — unified entry point for Agent OS
#
# Multi-Agent War-Room Orchestrator
#
# Usage: ostwin <command> [options]

set -euo pipefail

# Resolve AGENTS_DIR: search from cwd upward for .agents, fallback to script-relative
AGENTS_DIR=""
if [[ -d "$(pwd)/.agents" && -f "$(pwd)/.agents/config.json" ]]; then
  # Running from project root (e.g., /project)
  AGENTS_DIR="$(cd "$(pwd)/.agents" && pwd)"
elif [[ -f "$(pwd)/config.json" && -d "$(pwd)/bin" ]]; then
  # Running from inside .agents itself
  AGENTS_DIR="$(pwd)"
else
  # Walk up to find .agents (e.g., running from .agents/plans/)
  _dir="$(pwd)"
  while [[ "$_dir" != "/" ]]; do
    if [[ -f "$_dir/config.json" && -d "$_dir/bin" ]]; then
      AGENTS_DIR="$_dir"
      break
    fi
    if [[ -d "$_dir/.agents" && -f "$_dir/.agents/config.json" ]]; then
      AGENTS_DIR="$(cd "$_dir/.agents" && pwd)"
      break
    fi
    _dir="$(dirname "$_dir")"
  done
fi
# Final fallback: script-relative
if [[ -z "$AGENTS_DIR" ]]; then
  if [[ -L "$0" ]]; then
    REAL_PATH="$(readlink "$0")"
    BIN_DIR="$(cd "$(dirname "$REAL_PATH")" && pwd)"
  else
    BIN_DIR="$(cd "$(dirname "$0")" && pwd)"
  fi
  AGENTS_DIR="$(cd "$BIN_DIR/.." && pwd)"
fi
PYTHON="${AGENTS_DIR}/.venv/bin/python"
[[ -x "$PYTHON" ]] || PYTHON="python3"

# Version from config
VERSION=$("$PYTHON" -c "import json; print(json.load(open('$AGENTS_DIR/config.json'))['version'])" 2>/dev/null || echo "unknown")

show_help() {
  cat << HELP
ostwin v${VERSION} — Multi-Agent War-Room Orchestrator

Usage:
  ostwin <command> [options]

Commands:
  run <plan.md>     Execute a plan file
                    Options: --dry-run, --max-rooms N, --working-dir PATH
  plan <sub>        Plan management (AI-assisted)
                    Subcommands: create, start [plan-file], list
  init [directory]  Scaffold Agent OS into a project
  status            Show war-room dashboard
                    Options: --json, --watch
  logs [room-id]    View channel logs
                    Options: --follow, --type TYPE, --last N
  stop              Graceful shutdown of running manager
                    Options: --force
  dashboard         Launch web dashboard
                    Options: --port PORT, --project-dir PATH
  config            View or update configuration
                    Options: --get KEY, --set KEY VALUE
  health            Check system health
  test              Run test suites
                    Options: --suite NAME, --verbose
  version           Show version

Examples:
  ostwin run plans/my-feature.md
  ostwin run plans/my-feature.md --dry-run
  ostwin status --watch
  ostwin logs room-001 --follow
  ostwin stop

Environment:
  ENGINEER_CMD        Override engineer CLI
  QA_CMD              Override QA CLI
  MOCK_SIGNOFF        Set to "true" for auto-signoff (testing)
  AGENT_OS_LOG_LEVEL  Log level: DEBUG, INFO, WARN, ERROR (default: INFO)
  WARROOMS_DIR        Override war-rooms data directory
                      (default: <project>/.war-rooms)
HELP
}

# Default WARROOMS_DIR to cwd/.war-rooms for project-scoped commands
export WARROOMS_DIR="${WARROOMS_DIR:-$(pwd)/.war-rooms}"

# PowerShell dispatch: prefer .ps1 scripts via pwsh when available
HAS_PWSH=false
if command -v pwsh &>/dev/null; then
  HAS_PWSH=true
fi

ps_dispatch() {
  # Usage: ps_dispatch <ps1-script> <fallback-sh-script> [args...]
  local ps1="$1"; shift
  local sh="$1"; shift
  if $HAS_PWSH && [[ -f "$ps1" ]]; then
    # Translate bash-style args to PowerShell params
    local ps_args=()
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --dry-run)      ps_args+=("-DryRun"); shift ;;
        --max-rooms)    ps_args+=("-MaxConcurrent" "$2"); shift 2 ;;
        --working-dir)  ps_args+=("-ProjectDir" "$2"); shift 2 ;;
        --non-interactive|-n) ps_args+=("-NonInteractive"); shift ;;
        --goal)         ps_args+=("-Goal" "$2"); shift 2 ;;
        --plan-file)    ps_args+=("-PlanFile" "$2"); shift 2 ;;
        --json)         ps_args+=("-AsJson"); shift ;;
        --watch)        ps_args+=("-Watch"); shift ;;
        *)              ps_args+=("$1"); shift ;;
      esac
    done
    exec pwsh -NoProfile -File "$ps1" "${ps_args[@]}"
  elif [[ -f "$sh" ]]; then
    exec "$sh" "$@"
  else
    echo "[ERROR] Neither $ps1 nor $sh found." >&2
    exit 1
  fi
}

case "${1:-}" in
  run)
    shift
    ps_dispatch "$AGENTS_DIR/plan/Start-Plan.ps1" "$AGENTS_DIR/run.sh" "$@"
    ;;
  plan)
    shift
    SUB="${1:-create}"
    case "$SUB" in
      create)
        shift
        ps_dispatch "$AGENTS_DIR/plan/New-Plan.ps1" "$AGENTS_DIR/plan.sh" -ProjectDir "$(pwd)" "$@"
        ;;
      start)
        shift
        ps_dispatch "$AGENTS_DIR/plan/Start-Plan.ps1" "$AGENTS_DIR/run.sh" "$@"
        ;;
      *)
        exec "$AGENTS_DIR/plan.sh" "$SUB" "$@"
        ;;
    esac
    ;;
  init)
    shift
    exec "$AGENTS_DIR/init.sh" "$@"
    ;;
  status)
    shift
    ps_dispatch "$AGENTS_DIR/war-rooms/Get-WarRoomStatus.ps1" "$AGENTS_DIR/war-rooms/status.sh" "$@"
    ;;
  logs)
    shift
    exec "$AGENTS_DIR/logs.sh" "$@"
    ;;
  stop)
    shift
    exec "$AGENTS_DIR/stop.sh" "$@"
    ;;
  dashboard)
    shift
    # Default project-dir to cwd if not specified
    if ! echo "$*" | grep -q -- "--project-dir"; then
      exec "$AGENTS_DIR/dashboard.sh" --project-dir "$(pwd)" "$@"
    else
      exec "$AGENTS_DIR/dashboard.sh" "$@"
    fi
    ;;
  config)
    shift
    exec "$AGENTS_DIR/config.sh" "$@"
    ;;
  health)
    shift
    exec "$AGENTS_DIR/health.sh" "$@"
    ;;
  test)
    shift
    exec "$AGENTS_DIR/tests/run-all.sh" "$@"
    ;;
  test-ps)
    # Run Pester tests for PowerShell modules
    shift
    if $HAS_PWSH; then
      exec pwsh -NoProfile -Command "
        Invoke-Pester '$AGENTS_DIR/lib','$AGENTS_DIR/channel','$AGENTS_DIR/war-rooms','$AGENTS_DIR/roles','$AGENTS_DIR/plan' -Output Detailed
      "
    else
      echo "[ERROR] pwsh (PowerShell) not found. Install: https://aka.ms/install-powershell" >&2
      exit 1
    fi
    ;;
  version|-v|--version)
    echo "ostwin v${VERSION}"
    ;;
  -h|--help|help)
    show_help
    ;;
  "")
    show_help
    ;;
  *)
    echo "Unknown command: $1" >&2
    echo "Run 'ostwin --help' for usage." >&2
    exit 1
    ;;
esac
