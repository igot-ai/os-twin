#!/usr/bin/env bash
# ostwin CLI — unified entry point for Agent OS
#
# Multi-Agent War-Room Orchestrator
#
# Usage: ostwin <command> [options]

set -euo pipefail

# Resolve AGENTS_DIR: search from cwd upward for .agents, fallback to script-relative
AGENTS_DIR=""
if [[ -d "$(pwd)/.agents" && -f "$(pwd)/.agents/config.json" ]]; then
  # Running from project root (e.g., /project)
  AGENTS_DIR="$(cd "$(pwd)/.agents" && pwd)"
elif [[ -f "$(pwd)/config.json" && -d "$(pwd)/bin" ]]; then
  # Running from inside .agents itself
  AGENTS_DIR="$(pwd)"
else
  # Walk up to find .agents (e.g., running from .agents/plans/)
  _dir="$(pwd)"
  while [[ "$_dir" != "/" ]]; do
    if [[ -f "$_dir/config.json" && -d "$_dir/bin" ]]; then
      AGENTS_DIR="$_dir"
      break
    fi
    if [[ -d "$_dir/.agents" && -f "$_dir/.agents/config.json" ]]; then
      AGENTS_DIR="$(cd "$_dir/.agents" && pwd)"
      break
    fi
    _dir="$(dirname "$_dir")"
  done
fi
# Final fallback: script-relative
if [[ -z "$AGENTS_DIR" ]]; then
  if [[ -L "$0" ]]; then
    REAL_PATH="$(readlink "$0")"
    BIN_DIR="$(cd "$(dirname "$REAL_PATH")" && pwd)"
  else
    BIN_DIR="$(cd "$(dirname "$0")" && pwd)"
  fi
  AGENTS_DIR="$(cd "$BIN_DIR/.." && pwd)"
fi
PYTHON="${AGENTS_DIR}/.venv/bin/python"
[[ -x "$PYTHON" ]] || PYTHON="$HOME/.ostwin/.venv/bin/python"
[[ -x "$PYTHON" ]] || PYTHON="python3"

# --- Load .env files (available to ALL subcommands) ---
# Priority: ~/.ostwin/.env (global) → $AGENTS_DIR/.env (project)
# Only set vars that are not already in the environment.
_load_env_file() {
  local envfile="$1"
  [[ -f "$envfile" ]] || return 0
  while IFS= read -r line || [[ -n "$line" ]]; do
    # Skip comments and blank lines
    [[ "$line" =~ ^[[:space:]]*# ]] && continue
    [[ -z "${line// /}" ]] && continue
    # Extract KEY=VALUE (strip surrounding quotes from value)
    local key="${line%%=*}"
    local val="${line#*=}"
    key="${key// /}"
    val="${val#\"}" ; val="${val%\"}"
    val="${val#\'}" ; val="${val%\'}"
    # Only export if not already set in the environment
    if [[ -n "$key" && -z "${!key+x}" ]]; then
      export "$key=$val"
    fi
  done < "$envfile"
}
_load_env_file "$HOME/.ostwin/.env"
_load_env_file "$AGENTS_DIR/.env"

# Resolve the Python that has deepagents_cli installed (uv-tool env).
# Priority: shebang of the deepagents binary → sibling python3 → fallback to $PYTHON.
DEEPAGENTS_PYTHON="$PYTHON"
if command -v deepagents &>/dev/null; then
  _DA_BIN="$(command -v deepagents)"
  # Extract interpreter from shebang line (e.g. #!/path/to/python)
  _DA_SHEBANG_PY="$(head -1 "$_DA_BIN" 2>/dev/null | sed 's|^#!||')"
  if [[ -x "$_DA_SHEBANG_PY" ]]; then
    DEEPAGENTS_PYTHON="$_DA_SHEBANG_PY"
  else
    # Try python3 sibling in the same bin dir as deepagents
    _DA_BIN_DIR="$(dirname "$(realpath "$_DA_BIN" 2>/dev/null || echo "$_DA_BIN")")"
    if [[ -x "$_DA_BIN_DIR/python3" ]]; then
      DEEPAGENTS_PYTHON="$_DA_BIN_DIR/python3"
    elif [[ -x "$_DA_BIN_DIR/python" ]]; then
      DEEPAGENTS_PYTHON="$_DA_BIN_DIR/python"
    fi
  fi
fi

# Version from config
VERSION=$("$PYTHON" -c "import json; print(json.load(open('$AGENTS_DIR/config.json'))['version'])" 2>/dev/null || echo "unknown")

# Dashboard URL
DASHBOARD_URL="${DASHBOARD_URL:-http://localhost:9000}"

# Build curl auth args from OSTWIN_API_KEY (array to preserve quoting)
CURL_AUTH=()
if [[ -n "${OSTWIN_API_KEY:-}" ]]; then
  CURL_AUTH=(-H "X-API-Key: ${OSTWIN_API_KEY}")
fi

# Resolve a plan_id to a plan file path + working_dir.
# If the argument looks like a hex plan_id (not a file path), resolve via the API.
# Sets: RESOLVED_PLAN_FILE and RESOLVED_WORKING_DIR
# Returns 0 on success, 1 on failure.
resolve_plan_id() {
  local arg="$1"

  # If it's an existing file, use it directly — backward compat
  if [[ -f "$arg" ]]; then
    RESOLVED_PLAN_FILE="$arg"
    RESOLVED_WORKING_DIR=""
    return 0
  fi

  # If it looks like a hex plan_id (8-64 hex characters, no slashes/dots)
  if [[ "$arg" =~ ^[0-9a-fA-F]{8,64}$ ]]; then
    # Try to resolve from the API
    if curl -sf "${CURL_AUTH[@]}" "${DASHBOARD_URL}/api/status" >/dev/null 2>&1; then
      local api_response
      api_response=$(curl -sf "${CURL_AUTH[@]}" "${DASHBOARD_URL}/api/plans/${arg}" 2>&1)
      if [[ $? -eq 0 && -n "$api_response" ]]; then
        RESOLVED_PLAN_FILE=$(echo "$api_response" | "$PYTHON" -c "
import sys, json, os
data = json.load(sys.stdin)
plan = data.get('plan', {})
filename = plan.get('filename', '')
if filename:
    # Try project-local AGENTS_DIR/plans/ first, then global ~/.ostwin/plans/
    candidates = [
        os.path.join('$AGENTS_DIR', 'plans', filename),
        os.path.join(os.path.expanduser('~'), '.ostwin', 'plans', filename),
    ]
    for c in candidates:
        if os.path.isfile(c):
            print(c)
            break
    else:
        # None found — print first candidate for error message
        print(candidates[0])
else:
    print('')
" 2>/dev/null)
        RESOLVED_WORKING_DIR=$(echo "$api_response" | "$PYTHON" -c "
import sys, json
data = json.load(sys.stdin)
plan = data.get('plan', {})
print(plan.get('working_dir', plan.get('meta', {}).get('working_dir', '')))
" 2>/dev/null)

        if [[ -n "$RESOLVED_PLAN_FILE" && -f "$RESOLVED_PLAN_FILE" ]]; then
          echo "✓ Resolved plan_id '$arg' → $RESOLVED_PLAN_FILE"
          if [[ -n "$RESOLVED_WORKING_DIR" ]]; then
            echo "  Working dir: $RESOLVED_WORKING_DIR"
          fi
          return 0
        else
          echo "✗ Plan file not found for plan_id '$arg'" >&2
          echo "  Searched: $AGENTS_DIR/plans/ and ~/.ostwin/plans/" >&2
          return 1
        fi
      else
        echo "✗ Plan '$arg' not found via API" >&2
        return 1
      fi
    else
      echo "⚠ Dashboard not reachable at ${DASHBOARD_URL}" >&2
      echo "  Cannot resolve plan_id. Start dashboard or pass a file path." >&2
      return 1
    fi
  fi

  # Not a file and not a hex plan_id — just pass through
  RESOLVED_PLAN_FILE="$arg"
  RESOLVED_WORKING_DIR=""
  return 0
}

show_help() {
  cat << HELP
ostwin v${VERSION} — Multi-Agent War-Room Orchestrator

Usage:
  ostwin <command> [options]

Commands:
  agent [args...]    Run the Agent OS CLI (role-aware deepagents wrapper)
  chat [options]    Interactive AI chat session
                    Options: -a AGENT, -M MODEL, -m MSG, --auto-approve, -r [ID]
  run <plan_id|file> Execute a plan by ID or file path
                    Options: --dry-run, --resume, --expand, --working-dir PATH
  resume <plan_id|file>  Resume a previously failed/stopped plan run
                    Shortcut for: ostwin run <arg> --resume
  plan <sub>        Plan management (AI-assisted)
                    Subcommands: create [Title|file.md] [--file FILE], start, list
  init [directory]  Scaffold Agent OS into a project
  status            Show war-room dashboard
                    Options: --json, --watch
  logs [room-id]    View channel logs
                    Options: --follow, --type TYPE, --last N
  stop              Graceful shutdown of running manager
                    Options: --force
  dashboard         Launch web dashboard
                    Options: --port PORT, --project-dir PATH
  clone-role <role> Clone a role to project-local for override
                    Options: --project-dir PATH
  orphans           Manage orphaned agent processes
                    Options: --list, --kill, --json
  config            View or update configuration
                    Options: --get KEY, --set KEY VALUE
  role <name> [sub]  Run a role's subcommand
                       Options: ostwin role (list roles)
                                ostwin role <name> (show subcommands)
                                ostwin role <name> <sub> [args...]
  health            Check system health
  skills <sub>      Manage skills installation and sync
                    Subcommands: sync, install [--from DIR], list
  mcp               Manage MCP extensions
                    Subcommands: install, list, catalog, remove, sync
  reload-env        Reload ~/.ostwin/.env into mcp-config.json env blocks
  test              Run test suites
                    Options: --suite NAME, --verbose
  version           Show version

Examples:
  ostwin run plans/my-feature.md
  ostwin run plans/my-feature.md --dry-run
  ostwin resume plans/my-feature.md
  ostwin run plans/my-feature.md --resume --expand
  ostwin status --watch
  ostwin logs room-001 --follow
  ostwin stop

Environment:
  ENGINEER_CMD        Override engineer CLI
  QA_CMD              Override QA CLI
  MOCK_SIGNOFF        Set to "true" for auto-signoff (testing)
  AGENT_OS_LOG_LEVEL  Log level: DEBUG, INFO, WARN, ERROR (default: INFO)
  WARROOMS_DIR        Override war-rooms data directory
                      (default: <project>/.war-rooms)
HELP
}

# Default WARROOMS_DIR to cwd/.war-rooms for project-scoped commands
export WARROOMS_DIR="${WARROOMS_DIR:-$(pwd)/.war-rooms}"

# PowerShell dispatch: prefer .ps1 scripts via pwsh when available
HAS_PWSH=false
if command -v pwsh &>/dev/null; then
  HAS_PWSH=true
fi

ps_dispatch() {
  # Usage: ps_dispatch <ps1-script> <fallback-sh-script> [args...]
  local ps1="$1"; shift
  local sh="$1"; shift
  if $HAS_PWSH && [[ -f "$ps1" ]]; then
    # Translate bash-style args to PowerShell params
    local ps_args=()
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --dry-run)      ps_args+=("-DryRun"); shift ;;
        --resume)       ps_args+=("-Resume"); shift ;;
        --expand)       ps_args+=("-Expand"); shift ;;
        --review)       ps_args+=("-Review"); shift ;;
        --max-rooms)    ps_args+=("-MaxConcurrent" "$2"); shift 2 ;;
        --working-dir)  ps_args+=("-ProjectDir" "$2"); shift 2 ;;
        --non-interactive|-n) ps_args+=("-NonInteractive"); shift ;;
        --goal)         ps_args+=("-Goal" "$2"); shift 2 ;;
        --plan-file)    ps_args+=("-PlanFile" "$2"); shift 2 ;;
        --file|-f)      ps_args+=("-InitFile" "$2"); shift 2 ;;
        --json)         ps_args+=("-AsJson"); shift ;;
        --watch)        ps_args+=("-Watch"); shift ;;
        --list)         ps_args+=("-List"); shift ;;
        --kill)         ps_args+=("-Kill"); shift ;;
        *)              ps_args+=("$1"); shift ;;
      esac
    done
    exec pwsh -NoProfile -File "$ps1" "${ps_args[@]}"
  elif [[ -f "$sh" ]]; then
    exec "$sh" "$@"
  else
    echo "[ERROR] Neither $ps1 nor $sh found." >&2
    exit 1
  fi
}

case "${1:-}" in
  agent)
    shift
    exec "$AGENTS_DIR/bin/agent" "$@"
    ;;
  chat)
    shift
    exec "$DEEPAGENTS_PYTHON" "$AGENTS_DIR/bin/chat.py" "$@"
    ;;
  run)
    shift
    # First non-flag argument may be a plan_id — resolve it
    RUN_ARGS=()
    PLAN_ARG_RESOLVED=false
    for a in "$@"; do
      if [[ "$PLAN_ARG_RESOLVED" == false && ! "$a" =~ ^-- ]]; then
        if resolve_plan_id "$a"; then
          RUN_ARGS+=("$RESOLVED_PLAN_FILE")
          if [[ -n "$RESOLVED_WORKING_DIR" ]]; then
            RUN_ARGS+=("--working-dir" "$RESOLVED_WORKING_DIR")
          fi
        else
          exit 1
        fi
        PLAN_ARG_RESOLVED=true
      else
        RUN_ARGS+=("$a")
      fi
    done

    # Check for missing roles in the plan and generate a script if needed
    if [[ "$PLAN_ARG_RESOLVED" == true && -f "$RESOLVED_PLAN_FILE" ]]; then
      # Extract roles defined as "Role: role-name"
      NEEDED_ROLES=$(awk -F': ' '/^Role:/ {print $2}' "$RESOLVED_PLAN_FILE" | sed 's/^[[:space:]]*//;s/[[:space:]].*//' | sort -u)
      MISSING_ROLES=()
      for r in $NEEDED_ROLES; do
        if [[ "$r" == "<role-name>" || -z "$r" ]]; then continue; fi
        if [[ ! -d "$AGENTS_DIR/roles/$r" && ! -d "$HOME/.ostwin/roles/$r" ]]; then
          MISSING_ROLES+=("$r")
        fi
      done
      
      if [[ ${#MISSING_ROLES[@]} -gt 0 ]]; then
        echo "⚠ Found missing roles needed by the plan: ${MISSING_ROLES[*]}"
        
        IS_INTERACTIVE=true
        if [[ ! -t 0 ]] || [[ " ${RUN_ARGS[*]} " =~ " --non-interactive " ]] || [[ " ${RUN_ARGS[*]} " =~ " -n " ]]; then
          IS_INTERACTIVE=false
        fi

        if [[ "$IS_INTERACTIVE" == true ]]; then
          read -p "Do you want the manager agent to automatically create these roles now? [Y/n] " -n 1 -r
          echo ""
        else
          echo "Non-interactive mode. Auto-creating missing roles..."
          REPLY="y"
        fi
        
        if [[ $REPLY =~ ^[Yy]$ ]] || [[ -z $REPLY ]]; then
            echo "Running manager agent to scaffold roles..."
            for mr in "${MISSING_ROLES[@]}"; do
              ( ps_dispatch "$AGENTS_DIR/bin/Auto-CreateRole.ps1" "$AGENTS_DIR/bin/auto_create_role.sh" "$mr" "$AGENTS_DIR" )
            done
            
            # Verify creation
            FAILED_ROLES=()
            for mr in "${MISSING_ROLES[@]}"; do
              if [[ ! -d "$AGENTS_DIR/roles/$mr" && ! -d "$HOME/.ostwin/roles/$mr" ]]; then
                FAILED_ROLES+=("$mr")
              fi
            done
            
            if [[ ${#FAILED_ROLES[@]} -gt 0 ]]; then
              echo "✗ Failed to create roles: ${FAILED_ROLES[*]}. Aborting."
              exit 1
            else
              echo "✓ Successfully created all missing roles."
              echo ""
            fi
        else
            echo "Aborting run. Please create the missing roles manually."
            exit 1
        fi
      fi
    fi

    ps_dispatch "$AGENTS_DIR/plan/Start-Plan.ps1" "$AGENTS_DIR/run.sh" "${RUN_ARGS[@]}"
    ;;
  resume)
    shift
    # First non-flag argument may be a plan_id — resolve it
    RESUME_ARGS=()
    RESUME_ARG_RESOLVED=false
    for a in "$@"; do
      if [[ "$RESUME_ARG_RESOLVED" == false && ! "$a" =~ ^-- ]]; then
        if resolve_plan_id "$a"; then
          RESUME_ARGS+=("$RESOLVED_PLAN_FILE")
          if [[ -n "$RESOLVED_WORKING_DIR" ]]; then
            RESUME_ARGS+=("--working-dir" "$RESOLVED_WORKING_DIR")
          fi
        else
          exit 1
        fi
        RESUME_ARG_RESOLVED=true
      else
        RESUME_ARGS+=("$a")
      fi
    done
    ps_dispatch "$AGENTS_DIR/plan/Start-Plan.ps1" "$AGENTS_DIR/run.sh" --resume "${RESUME_ARGS[@]}"
    ;;
  plan)
    shift
    SUB="${1:-create}"
    case "$SUB" in
      create)
        shift
        # ── ostwin plan create ["Title"] [--file FILE] ──
        # Calls dashboard API, creates a plan, and opens the editor in the browser.
        # If --file is given, the markdown file content seeds the plan's first version.
        PLAN_TITLE=""
        INIT_FILE=""
        PROJECT_DIR="$(pwd)"
        DASHBOARD_URL="${DASHBOARD_URL:-http://localhost:9000}"

        # Parse arguments: positional title/file and optional --file/-f
        # Smart detection: if a positional arg is an existing .md file, treat it as --file
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --file|-f)
              INIT_FILE="$2"
              shift 2
              ;;
            -*)
              echo "Unknown option for plan create: $1" >&2
              exit 1
              ;;
            *)
              # If the argument is an existing .md file, treat it as --file
              if [[ -z "$INIT_FILE" && -f "$1" && "$1" == *.md ]]; then
                INIT_FILE="$1"
              elif [[ -z "$PLAN_TITLE" ]]; then
                PLAN_TITLE="$1"
              fi
              shift
              ;;
          esac
        done

        # If --file provided, validate and read content
        INIT_CONTENT=""
        if [[ -n "$INIT_FILE" ]]; then
          if [[ ! -f "$INIT_FILE" ]]; then
            echo "✗ File not found: $INIT_FILE" >&2
            exit 1
          fi
          INIT_CONTENT=$(<"$INIT_FILE")

          # Extract title from markdown header if not explicitly provided
          if [[ -z "$PLAN_TITLE" ]]; then
            PLAN_TITLE=$("$PYTHON" -c "
import sys, re
content = sys.stdin.read()
m = re.search(r'^#\s+(?:Plan:\s*)?(.+)', content, re.MULTILINE)
if m:
    print(m.group(1).strip())
else:
    import os
    print(os.path.splitext(os.path.basename('$INIT_FILE'))[0])
" <<< "$INIT_CONTENT" 2>/dev/null)
          fi
        fi

        # Default title fallback
        PLAN_TITLE="${PLAN_TITLE:-Untitled}"

        # Check dashboard is reachable
        if ! curl -sf "${CURL_AUTH[@]}" "${DASHBOARD_URL}/api/status" >/dev/null 2>&1; then
          echo "⚠  Dashboard not reachable at ${DASHBOARD_URL}" >&2
          echo "   Start it with: ostwin dashboard" >&2
          exit 1
        fi

        # Build JSON payload (include content only if --file was given)
        JSON_PAYLOAD=$("$PYTHON" -c "
import json, sys
payload = {'path': '$PROJECT_DIR', 'title': '''$PLAN_TITLE'''}
content = sys.stdin.read()
if content.strip():
    payload['content'] = content
print(json.dumps(payload))
" <<< "$INIT_CONTENT" 2>/dev/null)

        # Create plan via API
        RESPONSE=$(curl -sf -X POST "${CURL_AUTH[@]}" "${DASHBOARD_URL}/api/plans/create" \
          -H "Content-Type: application/json" \
          -d "$JSON_PAYLOAD" 2>&1) || {
          echo "✗ Failed to create plan: ${RESPONSE}" >&2
          exit 1
        }

        # Parse plan_id and URL from response
        PLAN_ID=$(echo "$RESPONSE" | "$PYTHON" -c "import sys,json; print(json.load(sys.stdin)['plan_id'])" 2>/dev/null)
        PLAN_URL=$(echo "$RESPONSE" | "$PYTHON" -c "import sys,json; print(json.load(sys.stdin)['url'])" 2>/dev/null)

        if [[ -z "$PLAN_ID" ]]; then
          echo "✗ Failed to parse plan ID from response" >&2
          echo "  Response: $RESPONSE" >&2
          exit 1
        fi

        EDITOR_URL="${DASHBOARD_URL}${PLAN_URL}"
        echo "✓ Plan created: ${PLAN_ID}"
        echo "  Title:  ${PLAN_TITLE}"
        echo "  Dir:    ${PROJECT_DIR}"
        if [[ -n "$INIT_FILE" ]]; then
          echo "  Source: ${INIT_FILE}"
        fi
        echo "  Editor: ${EDITOR_URL}"

        # Open browser
        if command -v open &>/dev/null; then
          open "$EDITOR_URL"
        elif command -v xdg-open &>/dev/null; then
          xdg-open "$EDITOR_URL"
        else
          echo "  → Open this URL in your browser to edit the plan"
        fi
        ;;
      start)
        shift
        # First non-flag argument may be a plan_id — resolve it
        START_ARGS=()
        START_ARG_RESOLVED=false
        for a in "$@"; do
          if [[ "$START_ARG_RESOLVED" == false && ! "$a" =~ ^-- ]]; then
            if resolve_plan_id "$a"; then
              START_ARGS+=("$RESOLVED_PLAN_FILE")
              if [[ -n "$RESOLVED_WORKING_DIR" ]]; then
                START_ARGS+=("--working-dir" "$RESOLVED_WORKING_DIR")
              fi
            else
              exit 1
            fi
            START_ARG_RESOLVED=true
          else
            START_ARGS+=("$a")
          fi
        done
        ps_dispatch "$AGENTS_DIR/plan/Start-Plan.ps1" "$AGENTS_DIR/run.sh" "${START_ARGS[@]}"
        ;;
      list)
        # Quick list via API
        DASHBOARD_URL="${DASHBOARD_URL:-http://localhost:9000}"
        if curl -sf "${CURL_AUTH[@]}" "${DASHBOARD_URL}/api/status" >/dev/null 2>&1; then
          curl -sf "${CURL_AUTH[@]}" "${DASHBOARD_URL}/api/plans" | "$PYTHON" -c "
import sys, json
data = json.load(sys.stdin)
plans = data.get('plans', [])
if not plans:
    print('No plans found.')
else:
    for p in plans:
        status = p.get('status', 'unknown')
        print(f\"  {p['plan_id'][:12]}  {p.get('title','Untitled'):30s}  {status:10s}  {p.get('epic_count',0)} epics\")
" 2>/dev/null || echo "Failed to list plans."
        else
          echo "⚠  Dashboard not reachable at ${DASHBOARD_URL}" >&2
          exit 1
        fi
        ;;
      *)
        echo "Unknown plan subcommand: $SUB" >&2
        echo "  Usage: ostwin plan create [Title] [--file FILE]" >&2
        echo "         ostwin plan start [plan-file]" >&2
        echo "         ostwin plan list" >&2
        exit 1
        ;;
    esac
    ;;
  init)
    shift
    exec "$AGENTS_DIR/init.sh" "$@"
    ;;
  status)
    shift
    ps_dispatch "$AGENTS_DIR/war-rooms/Get-WarRoomStatus.ps1" "$AGENTS_DIR/war-rooms/status.sh" "$@"
    ;;
  logs)
    shift
    exec "$AGENTS_DIR/logs.sh" "$@"
    ;;
  stop)
    shift
    exec "$AGENTS_DIR/stop.sh" "$@"
    ;;
  dashboard)
    shift
    # Default project-dir to cwd if not specified
    if ! echo "$*" | grep -q -- "--project-dir"; then
      exec "$AGENTS_DIR/dashboard.sh" --project-dir "$(pwd)" "$@"
    else
      exec "$AGENTS_DIR/dashboard.sh" "$@"
    fi
    ;;
  clone-role)
    shift
    ROLE="$1"
    shift || { echo "Usage: ostwin clone-role <role> [--project-dir <path>]"; exit 1; }
    
    PROJECT_DIR="$(pwd)"
    # Simple parse for --project-dir
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --project-dir)
          shift
          PROJECT_DIR="$1"
          shift
          ;;
        *)
          # Ignore other args for now or pass them
          shift
          ;;
      esac
    done
    
    # Delegate to manager role clone
    # This assumes EPIC-002's "ostwin role" is implemented or we call the script directly.
    # Since EPIC-002 might not be fully done in this environment, let's use the dispatch logic if possible.
    # Actually, the instructions say: delegates to `ostwin role manager clone -RoleName <role> -ProjectDir <path>`.
    # Let's use that exact command.
    exec "$0" role manager clone -RoleName "$ROLE" -ProjectDir "$PROJECT_DIR"
    ;;
  orphans)
    shift
    ps_dispatch "$AGENTS_DIR/bin/Orphans.ps1" "" "$@"
    ;;
  skills)
    shift
    SUB="${1:-sync}"
    SYNC_SCRIPT="$AGENTS_DIR/sync-skills.sh"
    if [[ ! -x "$SYNC_SCRIPT" ]]; then
      # Fallback to installed home
      SYNC_SCRIPT="$HOME/.ostwin/sync-skills.sh"
    fi
    if [[ ! -x "$SYNC_SCRIPT" ]]; then
      echo "✗ sync-skills.sh not found" >&2
      exit 1
    fi
    case "$SUB" in
      sync)
        shift
        OSTWIN_HOME="$HOME/.ostwin" bash "$SYNC_SCRIPT" "$@"
        ;;
      install)
        shift
        # Determine source dir: --from DIR or current directory
        FROM_DIR=""
        EXTRA_ARGS=()
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --from) FROM_DIR="$2"; shift 2 ;;
            *)      EXTRA_ARGS+=("$1"); shift ;;
          esac
        done
        # Default: scan cwd for .agents/skills/
        if [[ -z "$FROM_DIR" ]]; then
          for candidate in \
            "$(pwd)/.agents/skills" \
            "$(pwd)/skills" \
            "$(pwd)"; do
            if [[ -d "$candidate" ]] && find "$candidate" -name "SKILL.md" -type f 2>/dev/null | head -1 | grep -q .; then
              FROM_DIR="$candidate"
              break
            fi
          done
        fi
        if [[ -z "$FROM_DIR" || ! -d "$FROM_DIR" ]]; then
          echo "✗ No skills found. Specify --from DIR or run from a project root." >&2
          exit 1
        fi
        echo "Installing skills from: $FROM_DIR"
        OSTWIN_HOME="$HOME/.ostwin" bash "$SYNC_SCRIPT" --install-from "$FROM_DIR" "${EXTRA_ARGS[@]}"
        ;;
      list)
        shift
        DASHBOARD_URL="${DASHBOARD_URL:-http://localhost:9000}"
        if curl -sf "${CURL_AUTH[@]}" "${DASHBOARD_URL}/api/status" >/dev/null 2>&1; then
          curl -sf "${CURL_AUTH[@]}" "${DASHBOARD_URL}/api/skills" | "$PYTHON" -c "
import sys, json
skills = json.load(sys.stdin)
if not skills:
    print('No skills found.')
else:
    for s in skills:
        tags = ', '.join(s.get('tags', []))
        print(f\"  {s['name']:30s}  {s.get('description','')[:50]:50s}  [{tags}]\")
" 2>/dev/null || echo "Failed to list skills."
        else
          echo "⚠  Dashboard not reachable at ${DASHBOARD_URL}" >&2
          exit 1
        fi
        ;;
      *)
        echo "Unknown skills subcommand: $SUB" >&2
        echo "  Usage: ostwin skills sync" >&2
        echo "         ostwin skills install [--from DIR]" >&2
        echo "         ostwin skills list" >&2
        exit 1
        ;;
    esac
    ;;
  mcp)
    shift
    exec "$AGENTS_DIR/mcp/mcp-extension.sh" "$@"
    ;;
  reload-env)
    shift
    ENV_FILE="$HOME/.ostwin/.env"
    if [[ ! -f "$ENV_FILE" ]]; then
      echo "✗ .env not found at $ENV_FILE" >&2
      exit 1
    fi

    # Collect all mcp-config.json files to patch
    MCP_CONFIGS=()
    [[ -f "$HOME/.ostwin/mcp/mcp-config.json" ]] && MCP_CONFIGS+=("$HOME/.ostwin/mcp/mcp-config.json")
    [[ -f "$AGENTS_DIR/mcp/mcp-config.json" ]] && MCP_CONFIGS+=("$AGENTS_DIR/mcp/mcp-config.json")
    # Deduplicate (in case they're the same file)
    MCP_CONFIGS=($(printf '%s\n' "${MCP_CONFIGS[@]}" | sort -u))

    if [[ ${#MCP_CONFIGS[@]} -eq 0 ]]; then
      echo "✗ No mcp-config.json found" >&2
      exit 1
    fi

    for MCP_CONFIG in "${MCP_CONFIGS[@]}"; do
      echo "Reloading $ENV_FILE → $MCP_CONFIG ..."
      "$PYTHON" - "$MCP_CONFIG" "$ENV_FILE" <<'PYEOF'
import json, sys

mcp_path, env_path = sys.argv[1], sys.argv[2]

# Parse .env
env_vars = {}
with open(env_path) as f:
    for line in f:
        line = line.strip()
        if not line or line.startswith('#'):
            continue
        if '=' not in line:
            continue
        key, _, val = line.partition('=')
        key = key.strip()
        val = val.strip().strip('"').strip("'")
        if key:
            env_vars[key] = val

if not env_vars:
    print('  No variables found in .env')
    sys.exit(0)

# Read and patch
with open(mcp_path) as f:
    config = json.load(f)

servers = config.get('mcpServers', {})
for name, server in servers.items():
    if 'env' not in server:
        server['env'] = {}
    for k, v in env_vars.items():
        server['env'][k] = v

with open(mcp_path, 'w') as f:
    json.dump(config, f, indent=2)
    f.write('\n')

print(f'  ✓ Injected {len(env_vars)} var(s) into {len(servers)} MCP server(s)')
for name in servers:
    print(f'    • {name}')
PYEOF
    done
    echo "Done."
    ;;
  config)
    shift
    exec "$AGENTS_DIR/config.sh" "$@"
    ;;
  health)
    shift
    exec "$AGENTS_DIR/health.sh" "$@"
    ;;
  test)
    shift
    exec "$AGENTS_DIR/tests/run-all.sh" "$@"
    ;;
  test-ps)
    # Run Pester tests for PowerShell modules
    shift
    if $HAS_PWSH; then
      exec pwsh -NoProfile -Command "
        Invoke-Pester '$AGENTS_DIR/lib','$AGENTS_DIR/channel','$AGENTS_DIR/war-rooms','$AGENTS_DIR/roles','$AGENTS_DIR/plan' -Output Detailed
      "
    else
      echo "[ERROR] pwsh (PowerShell) not found. Install: https://aka.ms/install-powershell" >&2
      exit 1
    fi
    ;;
  version|-v|--version)
    echo "ostwin v${VERSION}"
    ;;
  -h|--help|help)
    show_help
    ;;
  "")
    show_help
    ;;
  *)
    echo "Unknown command: $1" >&2
    echo "Run 'ostwin --help' for usage." >&2
    exit 1
    ;;
esac
