#!/usr/bin/env bash
# agent — bash entry point for Agent OS CLI
#
# Wraps opencode with environment resolution so roles can invoke via:
#   ostwin agent [args...]
#   .agents/bin/agent [args...]
#
# Environment variables (set automatically by Invoke-Agent.ps1):
#   AGENT_OS_ROLE       — active role name (engineer, qa, etc.)
#   AGENT_OS_SKILLS_DIR — isolated skills directory for this invocation
#   AGENT_OS_ROOM_DIR   — war-room directory path

set -euo pipefail

# --- Resolve AGENTS_DIR ---
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
AGENTS_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# --- Load .env files ---
_load_env_file() {
  local envfile="$1"
  [[ -f "$envfile" ]] || return 0
  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ "$line" =~ ^[[:space:]]*# ]] && continue
    [[ -z "${line// /}" ]] && continue
    local key="${line%%=*}"
    local val="${line#*=}"
    key="${key// /}"
    val="${val#\"}" ; val="${val%\"}"
    val="${val#\'}" ; val="${val%\'}"
    if [[ -n "$key" && -z "${!key+x}" ]]; then
      export "$key=$val"
    fi
  done < "$envfile"
}
_load_env_file "$HOME/.ostwin/.env"
_load_env_file "$AGENTS_DIR/.env"

# --- Self-register PID for orchestration tracking ---
# AGENT_OS_PID_FILE is set by Invoke-Agent.ps1 when launching via the
# orchestration system. When run standalone, this is a no-op.
if [[ -n "${AGENT_OS_PID_FILE:-}" ]]; then
  echo "$$" > "$AGENT_OS_PID_FILE"
fi

# --- Ensure opencode is available ---
if ! command -v opencode &>/dev/null; then
  echo "[agent] ERROR: opencode not found in PATH." >&2
  echo "  Install with: brew install anomalyco/tap/opencode" >&2
  echo "            or: curl -fsSL https://opencode.ai/install | bash" >&2
  exit 1
fi

# --- Execute opencode run with all arguments ---
exec opencode run "$@"
